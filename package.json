{
  "name": "pink-counter-desktop",
  "version": "1.1.0",
  "description": "핑크 계수기 — 글로벌 키보드 단축키 지원",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win portable"
  },
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "build": {
    "appId": "com.pinkcounter.desktop",
    "productName": "PinkCounter",
    "win": {
      "target": "portable"
    },
    "portable": {
      "artifactName": "PinkCounter.exe"
    },
    "files": [
      "main.js",
      "index.html",
      "node_modules/node-global-key-listener/**/*"
    ]
  },
  "devDependencies": {
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3"
  },
  "dependencies": {
    "node-global-key-listener": "^0.3.0"
  }
}
